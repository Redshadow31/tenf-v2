# Discord OAuth Configuration
# Obtenez ces valeurs depuis https://discord.com/developers/applications

# Client ID de votre application Discord
DISCORD_CLIENT_ID=your_discord_client_id_here

# Client Secret de votre application Discord
DISCORD_CLIENT_SECRET=your_discord_client_secret_here

# URL de redirection (doit correspondre à celle configurée dans Discord Developer Portal)
# Pour le développement local: http://localhost:3000/api/auth/discord/callback
# Pour la production: https://votre-domaine.com/api/auth/discord/callback
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/discord/callback

# URL de base de votre application (optionnel, utilisé pour construire les URLs)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here

# Twitch OAuth (liaison compte utilisateur)
TWITCH_CLIENT_ID=your_twitch_client_id_here
TWITCH_CLIENT_SECRET=your_twitch_client_secret_here
TWITCH_OAUTH_ENCRYPTION_KEY=your_strong_random_encryption_secret_here

# Twitch EventSub (pipeline test raids - Lot 2)
TWITCH_APP_CLIENT_ID=your_twitch_app_client_id_here
TWITCH_APP_CLIENT_SECRET=your_twitch_app_client_secret_here
TWITCH_EVENTSUB_SECRET=your_eventsub_secret_here
TWITCH_EVENTSUB_TEST_SECRET=your_eventsub_test_secret_here
RAID_EVENTSUB_TEST_ENABLED=false
RAID_EVENTSUB_TEST_CRON_SECRET=your_internal_cron_secret_here

# Snapshot follow admin (Netlify) : secret pour la background function uniquement (longue duree)
NETLIFY_FOLLOW_SNAPSHOT_BG_SECRET=your_random_secret_here

# Gate de production EventSub raids (true = ecrit dans le pipeline "vrai" raids)
RAID_EVENTSUB_PROD_ENABLED=true

# KPI go/no-go (Lot 5)
RAID_TEST_GO_MIN_COVERAGE_PCT=85
RAID_TEST_GO_MAX_EVENTS_ONLY_RATE_PCT=30
RAID_TEST_GO_MAX_SUB_FAILURE_RATE_PCT=20
RAID_TEST_GO_MAX_EVENT_ERROR_RATE_PCT=5
RAID_TEST_GO_MIN_DECLARATIONS_COUNT=10

# Page /lives — widget Streamlabs Charity (lu au runtime par /api/lives/streamlabs-charity-widget, pas dans le HTML de build)
# STREAMLABS_CHARITY_GOAL_WIDGET_URL=https://streamlabs.com/widgets/streamlabs-charity-donation-goal?token=...

# Barre /lives : API equipe (prioritaire), sinon lien UPA @equipe/slug, sinon jeton du widget (STREAMLABS_CHARITY_GOAL_WIDGET_URL) interroge des endpoints Streamlabs
# STREAMLABS_CHARITY_STATS_API_URL=https://streamlabscharity.com/api/v1/teams/@mon-equipe/ma-campagne
# Palier affiché pour la barre (prioritaire sur l objectif API). Ex. campagne 100 k€ mais barre sur 10 k€ : 10000
# STREAMLABS_CHARITY_BAR_GOAL_EUROS=10000
# Alias historique (meme effet si BAR non defini)
# STREAMLABS_CHARITY_GOAL_EUROS=10000
